{
  "name": "@hera-al/electronode",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform Hera node client with A2UI support (Electron + Vite + React + @a2ui/lit)",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac --arm64",
    "dist:win": "electron-vite build && electron-builder --win --x64",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@a2ui/lit": "^0.8.1",
    "@lit-labs/signals": "^0.1.3",
    "@lit/context": "^1.1.6",
    "lit": "^3.3.2",
    "lit-html": "^3.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.1",
    "signal-utils": "^0.21.1",
    "ws": "^8.16.0"
  },
  "build": {
    "appId": "com.hera-al.electronode",
    "productName": "ElectroNode",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/AppIcon.icns",
      "category": "public.app-category.utilities",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "Lorenzo Toscano (XL443D9DRG)"
    },
    "afterSign": "scripts/notarize.cjs",
    "dmg": {
      "sign": true
    },
    "win": {
      "target": "nsis",
      "icon": "resources/AppIcon.ico",
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
